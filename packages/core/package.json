{
  "name": "@canblmz1/dbsnap-core",
  "version": "0.9.0-beta.3",
  "description": "Core snapshot engine for dbsnap.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "keywords": [
    "database",
    "snapshot",
    "postgresql",
    "sqlite",
    "development"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canblmz1/dbsnap.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/canblmz1/dbsnap#readme",
  "bugs": {
    "url": "https://github.com/canblmz1/dbsnap/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "jiti": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
